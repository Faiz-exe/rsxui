{
  "name": "react-stylex-ui",
  "version": "1.0.0",
  "description": "RSX UI — A modern React component library built with StyleX. Zero-runtime CSS, fully typed, accessible by default, and themeable with design tokens.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/assets/stylex.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts && tsc --project tsconfig.lib.json",
    "lint": "eslint .",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "@stylexjs/stylex": ">=0.10.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "react-dom": {
      "optional": false
    }
  },
  "dependencies": {},
  "devDependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/literata": "^5.2.8",
    "@stylexjs/stylex": "^0.18.2",
    "@stylexjs/unplugin": "^0.18.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  },
  "keywords": [
    "react",
    "stylex",
    "components",
    "ui",
    "design-system",
    "accessible",
    "typescript",
    "theme",
    "tokens"
  ],
  "author": "Faiz-exe",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Faiz-exe/rsxui"
  },
  "homepage": "https://github.com/Faiz-exe/rsxui#readme",
  "bugs": {
    "url": "https://github.com/Faiz-exe/rsxui/issues"
  }
}
